an class=&#34;cl&#34;&gt;jq -r &lt;span class=&#34;s1&#34;&gt;&amp;#39;.results[] |  ( .properties |map(select(.key[] contains (&amp;#34;prod&amp;#34;)) &amp;#39;&lt;/span&gt;&#xA;&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&#xA;&lt;/div&gt;&#xA;&lt;/div&gt;</description>
